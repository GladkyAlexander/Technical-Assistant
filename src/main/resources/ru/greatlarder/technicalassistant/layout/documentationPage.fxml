<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>

<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<SplitPane fx:id="splitPaneDocumentation"
           maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
           prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.2-ea"
           fx:controller="ru.greatlarder.technicalassistant.controller.DocumentationPageController">
    <VBox fx:id="vBoxLeft" prefHeight="200.0" prefWidth="100.0">
        <padding>
            <Insets top="5.0" />
        </padding>
        <HBox prefWidth="200.0" spacing="10.0">
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
            <VBox.margin>
                <Insets left="10.0" />
            </VBox.margin>
            <Label cache="true" text="Учет :" textAlignment="CENTER">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Button fx:id="btnZip" mnemonicParsing="false" onMouseClicked="#zip" text="Сформировать документ ЗИП" textAlignment="CENTER" />
            <Button fx:id="btnLampProjector" mnemonicParsing="false" onAction="#createDocLamp" text="Сведения о лампе EXEL" />
            <Button fx:id="btnCreateTimeShite" mnemonicParsing="false" onMouseClicked="#createTimeShite" text="Учет рабочего времени" />
        </HBox>
    </VBox>
</SplitPane>
