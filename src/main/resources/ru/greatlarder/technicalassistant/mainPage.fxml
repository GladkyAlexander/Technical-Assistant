<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="borderPaneMainPage" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.greatlarder.technicalassistant.controller.MainController">
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
    <padding>
        <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
    </padding>
   <top>
      <GridPane alignment="CENTER_LEFT" BorderPane.alignment="CENTER_LEFT">
        <columnConstraints>
          <ColumnConstraints />
          <ColumnConstraints />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints />
        </rowConstraints>
         <children>
            <HBox alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1">
               <children>
                     <MenuButton fx:id="mbtLang" alignment="CENTER_RIGHT" contentDisplay="RIGHT" mnemonicParsing="false" text="Выберите язык">
                         <items>
                             <MenuItem fx:id="menuItemRu" mnemonicParsing="false" onAction="#mBru" text="Русский">
                                 <graphic>
                                     <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                         <image>
                                             <Image url="@images/ru.png" />
                                         </image>
                              </ImageView>
                                 </graphic>
                             </MenuItem>
                             <MenuItem fx:id="menuItemEn" mnemonicParsing="false" onAction="#mBen" text="English">
                                 <graphic>
                                     <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                         <image>
                                             <Image url="@images/ico-en.png" />
                                         </image>
                              </ImageView>
                                 </graphic>
                             </MenuItem>
                         </items>
                         <graphic>
                             <ImageView fx:id="imgLangMenuButton" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" />
                         </graphic>
                     </MenuButton>
               </children>
               <GridPane.margin>
                  <Insets left="10.0" right="10.0" />
               </GridPane.margin>
            </HBox>
              <HBox fx:id="hBoxTopToolbar" alignment="CENTER_LEFT" spacing="5.0">
      
                        <padding>
                      <Insets bottom="1.0" left="5.0" right="5.0" top="1.0" />
                  </padding>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
              </HBox>
         </children>
      </GridPane>
   </top>
</BorderPane>
