<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="borderPaneMainPage" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.greatlarder.technicalassistant.controller.MainController">
    <left>
        <SplitPane dividerPositions="0.19220055710306408" orientation="VERTICAL" prefHeight="716.0" prefWidth="221.0" BorderPane.alignment="CENTER">
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
            <HBox alignment="TOP_CENTER" prefHeight="131.0" prefWidth="220.0" spacing="2.0" SplitPane.resizableWithParent="false">
                <padding>
                    <Insets left="2.0" />
                </padding>
                <ImageView fx:id="imageViewLogo" fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                    <HBox.margin>
                        <Insets left="5.0" top="10.0" />
                    </HBox.margin>
                </ImageView>
                <VBox fx:id="vBoxNameCompany" alignment="CENTER" spacing="1.0" HBox.hgrow="ALWAYS">
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <effect>
                        <Glow />
                    </effect>
                    <HBox.margin>
                        <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                    </HBox.margin>
                    <padding>
                        <Insets left="2.0" />
                    </padding>
                    <MenuButton fx:id="btnSelectCompanies" alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onMouseClicked="#startMenuButton" text="Выберите Компанию" textAlignment="CENTER" textOverrun="CLIP">
                        <VBox.margin>
                            <Insets />
                        </VBox.margin>
                        <font>
                            <Font size="10.0" />
                        </font>
                    </MenuButton>
                    <TextField fx:id="ptAdr" cache="true" cacheHint="SCALE" editable="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" promptText="Адрес" />
                    <TextField fx:id="ptCur" editable="false" promptText="Куратор" />
                    <TextField fx:id="ptPhone" editable="false" promptText="Телефон куратора" />
                    <TextField fx:id="ptEmail" editable="false" promptText="Эл.почта" />
                </VBox>
            </HBox>
            <VBox fx:id="vBoxLeftButton" alignment="TOP_CENTER" cache="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="577.0" prefWidth="238.0" spacing="10.0">
                <padding>
                    <Insets top="10.0" />
                </padding>
                <Label fx:id="labelHomePage" onMouseClicked="#clickHomePage" text="Домашняя страница" textAlignment="CENTER" />
                <Label fx:id="labelManuals" onMouseClicked="#clickDocumentation" text="Документация" textAlignment="CENTER" />
                <Label fx:id="labelSettings" onMouseClicked="#clickPageSettings" text="Настройки" textAlignment="CENTER" />
                <HBox fx:id="hBoxInfo" alignment="CENTER" onMouseClicked="#openPageInfo" spacing="5.0">
                    <children>
                        <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/info.png" />
                            </image>
                        </ImageView>
                        <Label fx:id="labelInfo" text="Информация" />
                    </children>
                </HBox>
            </VBox>
        </SplitPane>
    </left>
    <top>
        <HBox fx:id="hBoxTopToolbar" alignment="CENTER_LEFT" spacing="5.0">

            <padding>
                <Insets bottom="2.0" left="5.0" right="5.0" top="2.0" />
            </padding>
            <ImageView fx:id="imgEquipment" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#allEquipment" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@images/all_equipment_un_active.png" />
                </image>
            </ImageView>
            <ImageView fx:id="imgTool" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#allListTool" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/tool_button_in_active.png" />
            </ImageView>
            <ImageView fx:id="imgIpAddress" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#allIpAddress" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/tool_box_ip_un_active.png" />
            </ImageView>
            <ImageView fx:id="imgAllDefect" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#allDefect" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/tool_box_defect_un_active.png" />
            </ImageView>
            <ImageView fx:id="imgAddEquipment" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#addEquipment" pickOnBounds="true" preserveRatio="true">
                <HBox.margin>
                    <Insets left="5.0" />
                </HBox.margin>
                <Image url="@images/add_equipment_un_active.png" />
            </ImageView>
            <ImageView fx:id="imgAddTool" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#addTool" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/tool_add_in_active.png" />
            </ImageView>
            <ImageView fx:id="imgAddDefect" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#addDefect" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/defect_add_un_active.png" />
            </ImageView>
            <ImageView fx:id="imgWatchWorkProg" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#watchWorkProjectors" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/add_time_un_active.png" />
            </ImageView>
            <ImageView fx:id="imgEngine" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#imgEnginSearch" pickOnBounds="true" preserveRatio="true" />
            <ImageView fx:id="imgAddTaskReception" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#addTask" pickOnBounds="true" preserveRatio="true" />
            <ImageView fitHeight="25.0" fitWidth="25.0" onMouseClicked="#addPhoneBook" pickOnBounds="true" preserveRatio="true" />
            <TextField fx:id="tfSerNum" prefHeight="20.0" prefWidth="224.0" promptText="Введите серийный номер устройства" />
            <ImageView fx:id="imgSearch" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#searchSerialNumber" pickOnBounds="true" preserveRatio="true">
                <Image url="@images/scale.png" />
            </ImageView>
            <MenuButton fx:id="mbtLang" mnemonicParsing="false" text="Выберите язык">
                <items>
                    <MenuItem fx:id="menuItemRu" mnemonicParsing="false" onAction="#mBru" text="Русский">
                        <graphic>
                            <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@images/ru.png" />
                                </image></ImageView>
                        </graphic>
                    </MenuItem>
                    <MenuItem fx:id="menuItemEn" mnemonicParsing="false" onAction="#mBen" text="English">
                        <graphic>
                            <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@images/ico-en.png" />
                                </image></ImageView>
                        </graphic>
                    </MenuItem>
                </items>
                <graphic>
                    <ImageView fx:id="imgLangMenuButton" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" />
                </graphic>
            </MenuButton>
        </HBox>
    </top>
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
    <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
    </padding>
    <center>
        <VBox fx:id="vBoxStartLayout" alignment="CENTER" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="labelWeAreGlad" alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" text="Мы рады Вашему выбору.">
                    <font>
                        <Font name="Bell MT Bold" size="36.0" />
                    </font>
                </Label>
                <Label fx:id="labelStartByRegistering" text="Начните с регистрации на странице &quot;Настройки&quot;.">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </center>
</BorderPane>
